local players = game:GetService("Players")
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local debris = game:GetService("Debris")
local tweenService = game:GetService("TweenService")

local plr = players.LocalPlayer
local char = plr.Character or plr.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")
local animator = humanoid:WaitForChild("Animator")
local animations = char:WaitForChild("OmniMan"):WaitForChild("Animations")
local omniScripts = char:WaitForChild("OmniMan")

local RS = game:GetService("ReplicatedStorage")
local omniRemotes = RS.Characters.OmniMan.Remotes
local combatRemotes = RS.Characters.Combat.Remotes
local flashRemotes = RS.Characters.TheFlashCw.Remotes
local conquestRemotes = RS.Characters.Conquest.Remotes

local chopRemote = omniRemotes.Chop
local clapRemote = omniRemotes.Clap
local spikeRemote = omniRemotes.Spike
local spikeHitRemote = omniRemotes.SpikeHit
local finisherRemote = omniRemotes.Finisher
local flightRemote = omniRemotes.Flight
local slamdownRemote = omniRemotes.Slamdown
local bash2Remote = RS.Characters.DarthVader.Remotes.Bash2
local combatHitbox = RS.Characters.Combat.Fx.CombatHitbox
local ezraLightning = flashRemotes.EzraLightning
local conquestFive = conquestRemotes.MoveFive

local counterActivate = omniScripts:WaitForChild("CounterActivate")
local destroyCounter = omniScripts:WaitForChild("DestroyCounter")

local chopAnim = animator:LoadAnimation(animations.Chop)
local clapAnim = animator:LoadAnimation(animations.Clap)
local spikeAnim = animator:LoadAnimation(animations.Spike)
local hammerAnim = animator:LoadAnimation(animations.Hammer)
local grabAnim = animator:LoadAnimation(animations.Grab)
local homecrusherAnim = animator:LoadAnimation(animations.Homecrusher)

local FLIGHT_SPEED = 120
local FLIGHT_SPEED_BOOST = 180
local FLIGHT_DURATION = 3
local flightActive = false
local flightConnection = nil
local ezraActive = false

local function fireMultiple(remote, count, interval, ...)
	local args = {...}
	for i = 1, count do
		remote:FireServer(table.unpack(args))
		task.wait(interval)
	end
end

local function spawnHitbox(offset, attachPart, duration, onHit)
	local clone = combatHitbox:Clone()
	if attachPart and attachPart.Size then
		clone.Size = attachPart.Size * 3
	end
	clone.Size = clone.Size + Vector3.new(6, 6, 6)
	clone.Parent = char
	local weld = Instance.new("Weld")
	weld.Part0 = clone
	weld.Part1 = attachPart or char.HumanoidRootPart
	weld.C0 = offset or CFrame.new(0, 0, 5)
	weld.Parent = clone
	debris:AddItem(clone, duration or 0.6)
	local hit = {}
	clone.Touched:Connect(function(part)
		if not part or not part.Parent then return end
		if part:IsDescendantOf(char) then return end
		local targetChar = part.Parent
		local targetH = targetChar:FindFirstChildOfClass("Humanoid")
		if not targetH or targetH.Health <= 0 then return end
		if table.find(hit, targetChar) then return end
		table.insert(hit, targetChar)
		onHit(targetChar, clone)
	end)
	return clone
end

local function stopFlight()
	if not flightActive then return end
	flightActive = false
	if flightConnection then
		flightConnection:Disconnect()
		flightConnection = nil
	end
	local flightHitbox = char:FindFirstChild("FlightHitbox")
	if flightHitbox then flightHitbox:Destroy() end
	homecrusherAnim:Stop(0.15)
	humanoid.PlatformStand = false
	humanoid.AutoRotate = true
	tweenService:Create(workspace.CurrentCamera, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {FieldOfView = 70}):Play()
	local root = char:FindFirstChild("HumanoidRootPart")
	if root then
		local lv = root:FindFirstChild("Emove_LV")
		local vf = root:FindFirstChild("Emove_AntiGravity")
		local att = root:FindFirstChild("Emove_Att")
		if lv then
			lv.VectorVelocity = Vector3.zero
			lv.MaxForce = 0
			lv:Destroy()
			if vf then vf:Destroy() end
			if att then att:Destroy() end
			root.AssemblyLinearVelocity = Vector3.zero
		else
			if vf then vf:Destroy() end
			if att then att:Destroy() end
		end
	end
end

local function doMoveOne()
	chopRemote:FireServer(plr)
	chopAnim:Play()
	local connection
	connection = chopAnim:GetMarkerReachedSignal("Chop"):Connect(function()
		connection:Disconnect()
		spawnHitbox(CFrame.new(0, 0, 5), nil, 0.6, function(targetChar)
			task.spawn(function() fireMultiple(bash2Remote, 25, 0, targetChar) end)
		end)
	end)
end

local function doMoveTwo()
	clapAnim:Play()
	clapRemote:FireServer(plr)
end

local function doMoveThree()
	counterActivate:FireServer(plr)
	slamdownRemote:FireServer(plr)
	destroyCounter:FireServer(plr)
end

local function doMoveFour(useHammer)
	local anim = useHammer and hammerAnim or spikeAnim
	local attachName = useHammer and "Hammer" or "Spike"
	anim:Play()
	spikeRemote:FireServer(attachName)
	local connection
	connection = anim:GetMarkerReachedSignal("Attack"):Connect(function()
		connection:Disconnect()
		local attachPart = char:FindFirstChild(attachName)
		local clone = combatHitbox:Clone()
		if attachPart then
			clone.Size = attachPart.Size * 3 + Vector3.new(6, 6, 6)
		end
		clone.Parent = char
		local weld = Instance.new("Weld")
		weld.Part0 = clone
		weld.Part1 = attachPart or char.HumanoidRootPart
		weld.C0 = CFrame.new()
		weld.Parent = clone
		debris:AddItem(clone, 1.2)
		local hit = {}
		clone.Touched:Connect(function(part)
			if not part or not part.Parent then return end
			if part:IsDescendantOf(char) then return end
			local targetChar = part.Parent
			local targetH = targetChar:FindFirstChildOfClass("Humanoid")
			if not targetH or targetH.Health <= 0 then return end
			if table.find(hit, targetChar) then return end
			table.insert(hit, targetChar)
			clone:Destroy()
			task.spawn(function() fireMultiple(spikeHitRemote, 25, 0, targetChar, attachName) end)
		end)
	end)
end

local function doMoveFive()
	grabAnim:Play()
	finisherRemote:FireServer()
end

local function doMoveE()
	if flightActive then
		stopFlight()
		return
	end

	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	flightActive = true
	homecrusherAnim:Play()
	flightRemote:FireServer()
	tweenService:Create(workspace.CurrentCamera, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {FieldOfView = 130}):Play()

	humanoid.PlatformStand = false
	humanoid.AutoRotate = true

	local att = Instance.new("Attachment")
	att.Name = "Emove_Att"
	att.Parent = root

	local lv = Instance.new("LinearVelocity")
	lv.Name = "Emove_LV"
	lv.Attachment0 = att
	lv.RelativeTo = Enum.ActuatorRelativeTo.World
	lv.MaxForce = math.huge
	lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
	lv.VectorVelocity = Vector3.new(0, 0, 0)
	lv.Parent = root

	local vf = Instance.new("VectorForce")
	vf.Name = "Emove_AntiGravity"
	vf.Attachment0 = att
	vf.RelativeTo = Enum.ActuatorRelativeTo.World
	vf.Force = Vector3.new(0, root.AssemblyMass * workspace.Gravity, 0)
	vf.Parent = root

	local elapsed = 0
	local smoothDir = root.CFrame.LookVector.Unit
	local hitTargets = {}

	local flightHitbox = combatHitbox:Clone()
	flightHitbox.Name = "FlightHitbox"
	flightHitbox.Size = Vector3.new(14, 14, 18)
	flightHitbox.Parent = char
	local flightWeld = Instance.new("Weld")
	flightWeld.Part0 = flightHitbox
	flightWeld.Part1 = root
	flightWeld.C0 = CFrame.new(0, 0, -3)
	flightWeld.Parent = flightHitbox
	debris:AddItem(flightHitbox, FLIGHT_DURATION + 1)

	flightHitbox.Touched:Connect(function(part)
		if not flightActive then return end
		if not part or not part.Parent then return end
		if part:IsDescendantOf(char) then return end
		local targetChar = part.Parent
		local targetH = targetChar:FindFirstChildOfClass("Humanoid")
		if not targetH or targetH.Health <= 0 then return end
		if table.find(hitTargets, targetChar) then return end
		table.insert(hitTargets, targetChar)
		task.spawn(function()
			fireMultiple(combatRemotes.Combo, 5, 0, targetChar)
			task.wait(1.5)
			local idx = table.find(hitTargets, targetChar)
			if idx then table.remove(hitTargets, idx) end
		end)
	end)

	task.delay(FLIGHT_DURATION, function()
		if not flightActive then return end
		stopFlight()
	end)

	flightConnection = runService.Heartbeat:Connect(function(dt)
		elapsed += dt

		if not root.Parent or not humanoid.Parent then
			stopFlight()
			return
		end

		if char:FindFirstChild("HitWhileFlying") then
			stopFlight()
			return
		end

		vf.Force = Vector3.new(0, root.AssemblyMass * workspace.Gravity, 0)
		lv.MaxForce = math.max(50000 * root.AssemblyMass, 1000000)

		local lookVec = root.CFrame.LookVector
		local clamped = Vector3.new(lookVec.X, math.clamp(lookVec.Y, -0.18, 0.25), lookVec.Z)
		local flatDir = Vector3.new(clamped.X, 0, clamped.Z)
		local wantedDir
		if flatDir.Magnitude > 0.001 then
			wantedDir = Vector3.new(flatDir.Unit.X, clamped.Y, flatDir.Unit.Z).Unit
		else
			wantedDir = Vector3.new(0, clamped.Y, -1).Unit
		end

		smoothDir = smoothDir:Lerp(wantedDir, math.clamp(dt * 10, 0, 1))
		if smoothDir.Magnitude > 0.001 then
			smoothDir = smoothDir.Unit
		end

		local speed = elapsed >= 1.5 and FLIGHT_SPEED_BOOST or FLIGHT_SPEED
		if elapsed >= 1.5 and elapsed - dt < 1.5 then
			tweenService:Create(workspace.CurrentCamera, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {FieldOfView = 160}):Play()
		end

		lv.VectorVelocity = smoothDir * speed
		root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
	end)
end

local function doDestroyCounter()
	destroyCounter:FireServer(plr)
end

local function doEzraToggle()
	ezraActive = not ezraActive
	ezraLightning:FireServer(ezraActive)
end

local function doConquestFive()
	conquestFive:FireServer()
end

local keyBinds = {
	[Enum.KeyCode.One]   = doMoveOne,
	[Enum.KeyCode.Two]   = doMoveTwo,
	[Enum.KeyCode.Three] = doMoveThree,
	[Enum.KeyCode.Four]  = function() doMoveFour(true) end,
	[Enum.KeyCode.Five]  = doMoveFive,
	[Enum.KeyCode.E]     = doMoveE,
	[Enum.KeyCode.G]     = doDestroyCounter,
	[Enum.KeyCode.H]     = doEzraToggle,
	[Enum.KeyCode.Z]     = doConquestFive,
}

userInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	local action = keyBinds[input.KeyCode]
	if action then action() end
end)
